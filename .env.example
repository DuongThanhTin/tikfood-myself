POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=n8n

API_POSTGRES_USER=tikfood
API_POSTGRES_PASSWORD=tikfood
API_POSTGRES_DB=tikfood
# Leave API_DATABASE_URL empty for Docker Compose so the API container uses api-db.
# For local API execution outside Docker, export:
# DATABASE_URL=postgres://tikfood:tikfood@localhost:15432/tikfood?sslmode=disable
API_DATABASE_URL=

N8N_ENCRYPTION_KEY=change_this_to_a_long_random_string
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

GITHUB_TOKEN=your_github_token_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

AI_AGENT_URL=

NEXT_PUBLIC_API_URL=http://localhost:18081
